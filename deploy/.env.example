# === Server Secrets (auto-generated by setup.sh) ===
VPN_SECRET_KEY=           # Fernet key for TOTP secret encryption
VPN_JWT_SECRET=           # HMAC secret for JWT signing

# === Admin User (created on first startup) ===
VPN_ADMIN_USERNAME=admin
VPN_ADMIN_PASSWORD=changeme

# === WireGuard ===
VPN_WG_ENDPOINT=vpn.example.com:51820  # Public endpoint for clients
VPN_WG_SUBNET=10.10.0.0/24            # VPN subnet (default)
VPN_WG_INTERFACE=wg0                   # Interface name (default)
VPN_WG_LISTEN_PORT=51820               # UDP port (default)

# === Server ===
VPN_SERVER_HOST=0.0.0.0                # Bind address (default)
VPN_SERVER_PORT=8000                   # Internal API port (default)
VPN_DB_PATH=/data/vpnservice.db       # SQLite path (default)

# === TLS (Caddy) ===
VPN_DOMAIN=vpn.example.com            # Domain for Caddy
TLS_MODE=internal                      # "internal" for self-signed, empty for Let's Encrypt
